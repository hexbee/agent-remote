# Required
TELEGRAM_BOT_TOKEN=86xxxxxx18:AAxxxxxxxxxxxxxxx8Y
TELEGRAM_CHAT_ID=86xxxxxx22

# Optional defaults
CLAUDE_SETTINGS_PATH=${HOME}/.claude/settings.json
TELEGRAM_MAX_MESSAGE_LENGTH=3500
CLAUDE_PENDING_MESSAGE="Processing your request..."
HEARTBEAT_KEYWORD=ping
HEARTBEAT_RESPONSE=pong
RAW_OUTPUT=0

# Set this in the parent shell before starting the app if you need a non-default env file path.
# ENV_FILE=./.env
