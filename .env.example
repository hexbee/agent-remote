# Primary runtime: app.py
# The legacy shell PoC only uses a subset of the shared and Claude variables below.

# Telegram
TELEGRAM_BOT_TOKEN=86xxxxxx18:AAxxxxxxxxxxxxxxx8Y
TELEGRAM_CHAT_ID=86xxxxxx22

# Claude Code
CLAUDE_EXECUTABLE=claude
CLAUDE_SETTINGS_PATH=${HOME}/.claude/settings.json
# Leave empty to default to the repository root when running app.py.
CLAUDE_WORKDIR=
# Set to 1 to append --no-session-persistence. Default behavior keeps session persistence.
CLAUDE_NO_SESSION_PERSISTENCE=0

# Codex CLI
CODEX_EXECUTABLE=codex
CODEX_MODEL=gpt-5.3-codex
CODEX_REASONING_EFFORT=high
# Leave empty to default to the repository root when running app.py.
CODEX_WORKDIR=

# Shared reply behavior
TELEGRAM_MAX_MESSAGE_LENGTH=3500
WATCH_POLL_TIMEOUT=10
CLAUDE_PENDING_MESSAGE="[CLAUDE CODE] Processing your request..."
CODEX_PENDING_MESSAGE="[CODEX CLI] Processing your request..."
HEARTBEAT_KEYWORD=ping
HEARTBEAT_RESPONSE=pong

# Debug output
RAW_OUTPUT=0

# Env file location
# Set this in the parent shell before starting the app if you need a non-default env file path.
# ENV_FILE=./.env
